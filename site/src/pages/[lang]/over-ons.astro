---
import Base from '../../layouts/Base.astro';
import { langPaths } from '../../i18n/paths';
import { useTranslations } from '../../i18n';
import { board, type Locale } from '../../data';
export const getStaticPaths = langPaths;

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL;
---
<Base locale={locale} current="about" title={t.about.title} description={t.about.missionText.slice(0, 155)}>
  <header class="page-head">
    <div class="wrap">
      <span class="eyebrow">{t.about.lead}</span>
      <h1>{t.about.title}</h1>
    </div>
  </header>

  <section class="section">
    <div class="wrap">
      <div class="split reveal">
        <div class="split-media"><img src={`${base}images/binnenplaats-1.jpg`} alt={t.gallery.courtyard} /><span class="frame"></span></div>
        <div class="stack">
          <span class="eyebrow">{t.about.missionTitle}</span>
          <h2>{t.about.missionTitle}</h2>
          <p class="prose">{t.about.missionText}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--cream">
    <div class="wrap">
      <div class="reveal" style="max-width:780px">
        <span class="eyebrow">{t.about.visionTitle}</span>
        <h2 style="margin:.4rem 0 1.2rem">{t.about.visionTitle}</h2>
        <div class="prose stack">
          {t.about.visionText.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="center reveal" style="margin-bottom:2.5rem">
        <span class="eyebrow">{t.about.boardTitle}</span>
        <h2 style="margin-top:.4rem">{t.about.boardTitle}</h2>
        <p class="lead" style="margin-top:.6rem">{t.about.boardIntro}</p>
      </div>
      <div class="grid grid-3 reveal">
        {board.map((m) => (
          <div class="card center card--feature">
            <span class="num">{t.about.roles[m.roleKey]}</span>
            <h3 style="color:var(--bordeaux)">{m.name}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
