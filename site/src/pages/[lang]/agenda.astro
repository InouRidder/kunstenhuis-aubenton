---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import { langPaths } from '../../i18n/paths';
import { useTranslations, localizedPath, shortDate, formatRange } from '../../i18n';
import { agendaItems, agendaYear, type Locale } from '../../data';
export const getStaticPaths = langPaths;

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const lead = t.agenda.lead.replace('{year}', String(agendaYear));
---
<Base locale={locale} current="agenda" title={t.agenda.title} description={lead}>
  <header class="page-head">
    <div class="wrap">
      <span class="eyebrow">{agendaYear}</span>
      <h1>{t.agenda.title}</h1>
      <p class="lead">{lead}</p>
    </div>
  </header>

  <section class="section">
    <div class="wrap" style="max-width:840px">
      {agendaItems.length === 0 ? (
        <p class="lead center">{t.agenda.empty}</p>
      ) : (
        <ul class="agenda-list reveal">
          {agendaItems.map((it) => {
            const sd = shortDate(locale, it.start);
            return (
              <li class="agenda-item">
                <div class="agenda-date"><span class="d">{sd.day}</span><span class="m">{sd.month}</span></div>
                <div class="agenda-body">
                  <div class="org">{it.org}</div>
                  <div class="ttl">{t.agenda.items[it.titleKey as keyof typeof t.agenda.items]}</div>
                  <div class="range">{formatRange(locale, it.start, it.end)}</div>
                </div>
                <span class="tag">{t.agenda.residency}</span>
              </li>
            );
          })}
        </ul>
      )}

      <div class="card reveal" style="margin-top:3rem;background:var(--cream);border-color:var(--gold)">
        <p class="prose" style="margin-bottom:1.2rem">{t.agenda.note}</p>
        <a class="link-arrow" href={localizedPath(locale, 'contact')}>{t.common.getInTouch}<Icon name="arrow" size={15} class="arrow" /></a>
      </div>
    </div>
  </section>
</Base>
