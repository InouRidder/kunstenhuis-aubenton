---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import { useTranslations, localizedPath } from '../../i18n';
import { disciplines, coordinators, type Locale } from '../../data';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const p = t.possibilities;
type DiscKey = keyof typeof p.disciplines;
const contactHref = localizedPath(locale, 'contact');
---
<Base locale={locale} current="possibilities" title={p.title} description={p.lead}>
  <header class="page-head">
    <div class="wrap">
      <span class="eyebrow">{t.nav.possibilities}</span>
      <h1>{p.title}</h1>
    </div>
  </header>

  <!-- BOOKING INTRO -->
  <section class="section">
    <div class="wrap" style="max-width:820px">
      <div class="prose reveal">
        <p style="font-size:1.08rem">{p.lead}</p>
        <p style="margin-top:1.1rem">
          {p.bookingContactPre}<a class="text-link" href={contactHref}>{p.bookingContactLink}</a>{p.bookingContactPost}
        </p>
      </div>
      <div class="reveal" style="margin-top:1.8rem">
        <a class="btn" href={contactHref}>{t.common.getInTouch}<Icon name="arrow" size={16} class="arrow" /></a>
      </div>
    </div>
  </section>

  <!-- WORKSHOPS & COORDINATION -->
  <section class="section section--cream">
    <div class="wrap" style="max-width:820px">
      <div class="reveal" style="margin-bottom:2rem">
        <span class="eyebrow">{p.coordTitle}</span>
        <h2 style="margin-top:.4rem">{p.coordTitle}</h2>
        <p class="lead" style="margin-top:.6rem">{p.coordIntro}</p>
      </div>
      <ul class="coord-list reveal">
        {coordinators.map((c) => (
          <li class="coord-item">
            <span class="coord-area">{p.coord[c.area]}</span>
            {c.email ? (
              <a class="coord-mail" href={`mailto:${c.email}`}><Icon name="mail" size={16} /> {c.email}</a>
            ) : (
              <span class="coord-person">{c.name}</span>
            )}
          </li>
        ))}
      </ul>

      <!-- Guidance · Meals · Accommodation -->
      <div class="trio reveal" style="margin-top:2.5rem">
        <div class="card">
          <h3>{p.trainersTitle}</h3>
          <p class="prose" style="margin-top:.6rem;font-size:.95rem">{p.trainersText}</p>
        </div>
        <div class="card">
          <h3>{p.mealsTitle}</h3>
          <p class="prose" style="margin-top:.6rem;font-size:.95rem">{p.mealsText}</p>
        </div>
        <div class="card">
          <h3>{p.accommodationTitle}</h3>
          <p class="prose" style="margin-top:.6rem;font-size:.95rem">{p.accommodationText}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- DISCIPLINES (at the bottom) -->
  <section class="section">
    <div class="wrap">
      <div class="center reveal" style="margin-bottom:2.2rem">
        <span class="eyebrow">{p.disciplinesTitle}</span>
      </div>
      <div class="tiles reveal">
        {disciplines.map((d) => {
          const info = p.disciplines[d.id as DiscKey];
          return (
            <div class="tile tile--static">
              <Icon name={d.icon} size={34} class="ic" />
              <span class="t-name">{info.name}</span>
              <span class="t-desc">{info.desc}</span>
            </div>
          );
        })}
      </div>
      <p class="center reveal" style="font-family:var(--serif);font-style:italic;font-size:1.4rem;color:var(--bordeaux);margin-top:2.5rem">
        {p.combine}
      </p>
    </div>
  </section>
</Base>
