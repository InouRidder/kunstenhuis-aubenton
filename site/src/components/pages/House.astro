---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n';
import { galleryImages, houseFeatureImages, omgevingImages, type Locale } from '../../data';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL;
const img = (n: string) => `${base}images/${n}.jpg`;
---
<Base locale={locale} current="house" title={t.house.title} description={t.house.introText[0]}>
  <header class="page-head">
    <div class="wrap">
      <span class="eyebrow">Aubenton · 1636</span>
      <h1>{t.house.title}</h1>
    </div>
  </header>

  <section class="section">
    <div class="wrap">
      <div class="split reveal">
        <div class="split-media"><img src={img('pand-pleintje')} alt={t.meta.siteName} /><span class="frame"></span></div>
        <div class="stack">
          <h2>{t.house.introTitle}</h2>
          <div class="prose stack">
            {t.house.introText.map((p) => <p>{p}</p>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section section--cream">
    <div class="wrap">
      <div class="grid grid-3 reveal" style="align-items:start">
        {t.house.features.map((f, i) => (
          <div class="card card--feature card--photo">
            <img src={img(houseFeatureImages[i])} alt={f.t} loading="lazy" />
            <div class="feature-body">
              <h3>{f.t}</h3>
              <p class="prose" style="font-size:.95rem;margin-top:.5rem">{f.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section section--paper">
    <div class="wrap">
      <div class="center reveal" style="margin-bottom:2.5rem">
        <span class="eyebrow">{t.house.galleryTitle}</span>
        <h2 style="margin-top:.4rem">{t.house.galleryTitle}</h2>
        <p class="lead" style="margin-top:.5rem">{t.house.galleryNote}</p>
      </div>
      <div class="gallery reveal">
        {galleryImages.map((g) => (
          <figure tabindex="0">
            <img src={img(g.src)} alt={t.gallery[g.cap]} loading="lazy" />
            <figcaption>{t.gallery[g.cap]}</figcaption>
          </figure>
        ))}
      </div>
      <p class="center lead reveal" style="margin-top:2.5rem;font-size:.95rem">{t.house.soon}</p>
    </div>
  </section>

  <!-- AUBENTON & SURROUNDINGS -->
  <section class="section section--cream">
    <div class="wrap">
      <div class="reveal" style="max-width:760px;margin-inline:auto;text-align:center">
        <span class="eyebrow">{t.house.omgevingTitle}</span>
        <h2 style="margin-top:.5rem">{t.house.omgevingSubtitle}</h2>
      </div>
      <div class="prose stack reveal" style="max-width:680px;margin:1.8rem auto 0">
        {t.house.omgevingText.map((p) => <p>{p}</p>)}
      </div>
      <p class="center lead reveal" style="margin:2.5rem 0 1.5rem;font-size:.95rem">{t.house.omgevingNote}</p>
      <div class="gallery reveal">
        {omgevingImages.map((g) => (
          <figure tabindex="0">
            <img src={img(g.src)} alt={t.gallery[g.cap]} loading="lazy" />
            <figcaption>{t.gallery[g.cap]}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
</Base>
