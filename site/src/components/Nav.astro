---
import { navOrder, type Locale, type NavKey, locales } from '../data';
import { useTranslations, localizedPath } from '../i18n';

interface Props { locale: Locale; current: NavKey }
const { locale, current } = Astro.props;
const t = useTranslations(locale);
// Contact is shown as the CTA button; Privacy lives in the footer only.
const items = navOrder.filter((k) => k !== 'contact' && k !== 'privacy');
---
<nav class="nav" id="nav" aria-label="Hoofdmenu">
  <a class="nav-logo" href={localizedPath(locale, 'home')} aria-label={t.meta.siteName}>
    <svg class="mark" viewBox="0 0 44 44" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="22" cy="22" r="21" fill="#6B1A2A"/>
      <path d="M11 30V20l11-8 11 8v10" fill="none" stroke="#C9A96E" stroke-width="1.4"/>
      <path d="M11 30h22" stroke="#C9A96E" stroke-width="1.4"/>
      <path d="M9 21l13-9.5L35 21" fill="none" stroke="#E8D4A8" stroke-width="1.4"/>
      <rect x="19.5" y="23" width="5" height="7" fill="none" stroke="#C9A96E" stroke-width="1.1"/>
      <circle cx="22" cy="16.5" r="1.4" fill="#E8D4A8"/>
    </svg>
    <span class="nav-title">
      <span class="nav-title-main">Kunstenhuis Aubenton</span>
      <span class="nav-title-sub">{t.meta.subtitle}</span>
    </span>
  </a>

  <div class="lang" role="group" aria-label="Taal / Language / Langue">
    {locales.map((l) => (
      <a href={localizedPath(l, current)} aria-current={l === locale ? 'true' : undefined} lang={l}>{l}</a>
    ))}
  </div>

  <ul class="nav-links" id="navLinks">
    {items.map((k) => (
      <li>
        <a href={localizedPath(locale, k)} aria-current={current === k ? 'page' : undefined}>{t.nav[k]}</a>
      </li>
    ))}
    <li>
      <a class="nav-cta" href={localizedPath(locale, 'contact')} aria-current={current === 'contact' ? 'page' : undefined}>{t.nav.contact}</a>
    </li>
  </ul>
</nav>

<script>
  const nav = document.getElementById('nav');
  const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 20);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // On mobile, bring the current page into view within the horizontal strip.
  const links = document.getElementById('navLinks');
  const active = links?.querySelector('[aria-current="page"]') as HTMLElement | null;
  if (links && active && links.scrollWidth > links.clientWidth) {
    links.scrollLeft = active.offsetLeft - links.clientWidth / 2 + active.clientWidth / 2;
  }
</script>
